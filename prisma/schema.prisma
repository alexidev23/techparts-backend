// ─── Prisma Schema — TechParts ────────────────────────────────────────────────
// ORM: Prisma
// Base de datos: MySQL
// Ejecutar migraciones: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────
// Los enums limitan los valores posibles de un campo
// Coinciden con los tipos que ya tenés en el frontend

enum Role {
  admin
  user
}

enum UserStatus {
  active
  inactive
}

enum OrderStatus {
  procesando
  enviado
  entregado
  cancelado
}

enum ProductStatus {
  active // visible en la tienda
  inactive // oculto en la tienda
}

enum CategoryStatus {
  active
  inactive
}

// ─── USERS ────────────────────────────────────────────────────────────────────
// Tabla de usuarios — tanto clientes como administradores
// El rol determina a qué panel tiene acceso (frontend ya lo maneja)

model User {
  id         String     @id @default(uuid()) // UUID en lugar de autoincrement — más seguro para exponer en URLs
  name       String
  email      String     @unique // no pueden haber dos usuarios con el mismo email
  password   String // hasheada con bcrypt, nunca en texto plano
  phone      String? // opcional
  address    String? // dirección de envío
  postalCode String? // código postal
  province   String? // provincia
  country    String?    @default("Argentina")
  role       Role       @default(user) // por defecto todos son usuarios normales
  status     UserStatus @default(active)
  createdAt  DateTime   @default(now()) // fecha de registro automática
  updatedAt  DateTime   @updatedAt // se actualiza solo cuando cambia el registro

  // Relaciones — un usuario puede tener muchos pedidos y favoritos
  orders    Order[]
  favorites Favorite[]
}

// ─── CATEGORIES ───────────────────────────────────────────────────────────────
// Categorías principales — Pantallas, Baterías, Accesorios, Cases, etc.
// totaldeproductos NO se guarda acá — se calcula con una query cuando se necesita

model Category {
  id        String         @id @default(uuid())
  name      String         @unique
  status    CategoryStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relaciones
  subcategories Subcategory[] // una categoría tiene muchas subcategorías
  products      Product[] // una categoría tiene muchos productos
}

// ─── SUBCATEGORIES ────────────────────────────────────────────────────────────
// Subcategorías — por ejemplo: Pantallas > iPhone, Pantallas > Samsung, etc.

model Subcategory {
  id        String         @id @default(uuid())
  name      String
  status    CategoryStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relación con categoría principal — una subcategoría pertenece a una categoría
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Relación con productos
  products Product[]
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────
// Tabla principal de productos
// imgSecundarias van en tabla separada ProductImage — una columna no puede guardar múltiples imágenes

model Product {
  id              String        @id @default(uuid())
  name            String
  description     String        @db.Text // Text permite textos largos, String tiene límite de 191 chars en MySQL
  price           Decimal       @db.Decimal(10, 2) // Decimal para precios — nunca Float (problemas de redondeo)
  discountPercent Int?          @default(0) // % de descuento, opcional
  brand           String
  stock           Int           @default(0)
  rating          Decimal?      @db.Decimal(3, 2) // ej: 4.75
  imgPrincipal    String        @db.Text
  status          ProductStatus @default(active)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relación con categoría — un producto pertenece a una categoría
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Relación con subcategoría — opcional, un producto puede no tener subcategoría
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Relaciones
  images     ProductImage[] // imágenes secundarias
  orderItems OrderItem[] // aparece en items de pedidos
  favorites  Favorite[] // puede estar en favoritos de usuarios
}

// ─── PRODUCT IMAGES ───────────────────────────────────────────────────────────
// Imágenes secundarias del producto — separadas para poder tener N imágenes por producto

model ProductImage {
  id    String @id @default(uuid())
  url   String
  order Int    @default(0) // para ordenar las imágenes (primera, segunda, etc.)

  // Relación con producto
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // onDelete: Cascade — si se borra el producto, se borran sus imágenes también
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────
// Pedidos — cada vez que un usuario completa el checkout se crea un Order
// Los productos del pedido van en OrderItem — no como columna

model Order {
  id              String      @id @default(uuid())
  totalPrice      Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(procesando)
  shippingAddress String // dirección de envío al momento del pedido
  paymentId       String? // id de pago de Mercado Pago — llega en la URL de retorno
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relación con usuario — un pedido pertenece a un usuario
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relación con items del pedido
  items OrderItem[]
}

// ─── ORDER ITEMS ──────────────────────────────────────────────────────────────
// Items de cada pedido — tabla intermedia entre Order y Product
// Guardamos el precio AL MOMENTO DE LA COMPRA porque el precio del producto puede cambiar después

model OrderItem {
  id       String  @id @default(uuid())
  quantity Int
  price    Decimal @db.Decimal(10, 2) // precio unitario al momento de la compra

  // Relación con pedido
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relación con producto
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─── FAVORITES ────────────────────────────────────────────────────────────────
// Favoritos — tabla intermedia entre User y Product
// Un usuario puede tener muchos productos favoritos
// Un producto puede estar en favoritos de muchos usuarios

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relación con usuario
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relación con producto
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Un usuario no puede tener el mismo producto dos veces en favoritos
  @@unique([userId, productId])
}

model Sponsor {
  id        String        @id @default(uuid())
  name      String
  logo      String        @db.Text
  link      String
  status    ProductStatus @default(active)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
